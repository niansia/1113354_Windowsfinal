{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "types": ["node"],
    "rootDir": ".",
    "outDir": "../output/feature-tests",
    "noEmit": false
  },
  "include": [
    "src/types.ts",
    "src/data/fusionApps.ts",
    "src/i18n/strings.ts",
    "src/i18n/featureTranslations.ts",
    "src/i18n/localeFormatting.ts",
    "src/assistant/microphoneSelection.ts",
    "src/assistant/wakeWords.ts",
    "src/circuit/**/*.ts",
    "src/devlab/**/*.ts",
    "src/math/**/*.ts",
    "src/system/**/*.ts",
    "src/style/**/*.ts",
    "tests/appCatalog.test.ts",
    "tests/circuitSimulator.test.ts",
    "tests/developmentLab.test.ts",
    "tests/engineeringMath.test.ts",
    "tests/localeFormatting.test.ts",
    "tests/microphoneSelection.test.ts",
    "tests/powerActions.test.ts",
    "tests/styleEngine.test.ts",
    "tests/wakeWords.test.ts"
  ]
}
